window:
  opacity: 0.95
  dimensions:
    columns: 200
    lines: 80

font:
  normal:
    family: FiraCode Nerd Font
    style: Regular
  size: 14

key_bindings:
  - { key: N, mods: Command, action: CreateNewWindow }
colors:
  name: 3024 (light)
  author: Chris Kempson
  primary:
    background: "#f7f7f7"
    foreground: "#4a4543"
  cursor:
    text: "#f7f7f7"
    cursor: "#4a4543"
  normal:
    black: "#090300"
    red: "#db2d20"
    green: "#01a252"
    yellow: "#fded02"
    blue: "#01a0e4"
    magenta: "#a16a94"
    cyan: "#b5e4f4"
    white: "#a5a2a2"
  bright:
    black: "#5c5855"
    red: "#db2d20"
    green: "#01a252"
    yellow: "#fded02"
    blue: "#01a0e4"
    magenta: "#a16a94"
    cyan: "#b5e4f4"
    white: "#f7f7f7"
theme: 3024.light
