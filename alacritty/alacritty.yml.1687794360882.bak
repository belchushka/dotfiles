# Copyright (c) 2017-present Sven Greb <code@svengreb.de>

# Project:    Nord Alacritty
# Version:    0.1.0
# Repository: https://github.com/arcticicestudio/nord-alacritty
# License:    MIT
# References:
#   https://github.com/alacritty/alacritty
window:
  opacity: 1
  dimensions:
    columns: 200
    lines: 80

env:
  TERM: xterm-256color

font:
  # Normal (roman) font face
  normal:
    # family: Iosevka Extralight
    # family: Fira Code
    # family: Iosevka Nerd Font
    # family: Noto Sans Mono Light
    # family: FuraCode Nerd Font
    # family: FuraCode Nerd Font
    family: FiraCode Nerd Font
    # family: CascadiaCode Nerd Font
    # family: FantasqueSansMono Nerd Font Mono
    # family: VictorMono Nerd Font
    # family: Anonymice Nerd Font
    # family: Iosevka Nerd Font
    # family: SauceCodePro Nerd Font
    # The `style` can be specified to pick a specific face.
    # style: Light
    style: Regular

  size: 14

key_bindings:
  - { key: N, mods: Command, action: CreateNewWindow }

colors:
  name: TokyoNight Storm
  author: Folke
  # Default colors
  primary:
    background: '0x24283b'
    foreground: '0xc0caf5'

  # Normal colors
  normal:
    black: '0x1D202F'
    red: '0xf7768e'
    green: '0x9ece6a'
    yellow: '0xe0af68'
    blue: '0x7aa2f7'
    magenta: '0xbb9af7'
    cyan: '0x7dcfff'
    white: '0xa9b1d6'

  # Bright colors
  bright:
    black: '0x414868'
    red: '0xf7768e'
    green: '0x9ece6a'
    yellow: '0xe0af68'
    blue: '0x7aa2f7'
    magenta: '0xbb9af7'
    cyan: '0x7dcfff'
    white: '0xc0caf5'

  indexed_colors:
    - { index: 16, color: '0xff9e64' }
    - { index: 17, color: '0xdb4b4b' }
theme: Tokyonight_Storm
