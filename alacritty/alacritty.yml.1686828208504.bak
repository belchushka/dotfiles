# Copyright (c) 2017-present Sven Greb <code@svengreb.de>

# Project:    Nord Alacritty
# Version:    0.1.0
# Repository: https://github.com/arcticicestudio/nord-alacritty
# License:    MIT
# References:
#   https://github.com/alacritty/alacritty
window:
  opacity: 1
  dimensions:
    columns: 200
    lines: 80

env:
  TERM: xterm-256color

font:
  # Normal (roman) font face
  normal:
    # family: Iosevka Extralight
    # family: Fira Code
    # family: Iosevka Nerd Font
    # family: Noto Sans Mono Light
    # family: FuraCode Nerd Font
    # family: FuraCode Nerd Font
    family: FiraCode Nerd Font
    # family: CascadiaCode Nerd Font
    # family: FantasqueSansMono Nerd Font Mono
    # family: VictorMono Nerd Font
    # family: Anonymice Nerd Font
    # family: Iosevka Nerd Font
    # family: SauceCodePro Nerd Font
    # The `style` can be specified to pick a specific face.
    # style: Light
    style: Regular

  size: 14

key_bindings:
  - { key: N, mods: Command, action: CreateNewWindow }

colors:
  name: 3024 (dark)
  author: Chris Kempson
  primary:
    background: "#090300"
    foreground: "#a5a2a2"
  cursor:
    text: "#090300"
    cursor: "#a5a2a2"
  normal:
    black: "#090300"
    red: "#db2d20"
    green: "#01a252"
    yellow: "#fded02"
    blue: "#01a0e4"
    magenta: "#a16a94"
    cyan: "#b5e4f4"
    white: "#a5a2a2"
  bright:
    black: "#5c5855"
    red: "#db2d20"
    green: "#01a252"
    yellow: "#fded02"
    blue: "#01a0e4"
    magenta: "#a16a94"
    cyan: "#b5e4f4"
    white: "#f7f7f7"
theme: 3024.dark
