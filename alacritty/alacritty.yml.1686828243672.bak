# Project:    Nord Alacritty
# Version:    0.1.0
# Repository: https://github.com/arcticicestudio/nord-alacritty
# License:    MIT
# References:
#   https://github.com/alacritty/alacritty
window:
  opacity: 1
  dimensions:
    columns: 200
    lines: 80

env:
  TERM: xterm-256color

font:
  # Normal (roman) font face
  normal:
    # family: Iosevka Extralight
    # family: Fira Code
    # family: Iosevka Nerd Font
    # family: Noto Sans Mono Light
    # family: FuraCode Nerd Font
    # family: FuraCode Nerd Font
    family: FiraCode Nerd Font
    # family: CascadiaCode Nerd Font
    # family: FantasqueSansMono Nerd Font Mono
    # family: VictorMono Nerd Font
    # family: Anonymice Nerd Font
    # family: Iosevka Nerd Font
    # family: SauceCodePro Nerd Font
    # The `style` can be specified to pick a specific face.
    # style: Light
    style: Regular

  size: 14

key_bindings:
  - { key: N, mods: Command, action: CreateNewWindow }

colors:
  name: Count Von Count
  author: Baskerville
  primary:
    background: "#000000"
    foreground: "#919191"
  cursor:
    text: "#000000"
    cursor: "#919191"
  normal:
    black: "#303030"
    red: "#c10023"
    green: "#a83334"
    yellow: "#b51d2c"
    blue: "#8c4b46"
    magenta: "#7d534f"
    cyan: "#9a413d"
    white: "#c6c6c6"
  bright:
    black: "#5e5e5e"
    red: "#ff8781"
    green: "#ffa095"
    yellow: "#ff948b"
    blue: "#feb2aa"
    magenta: "#ebbbb5"
    cyan: "#ffaaa0"
    white: "#ffffff"
theme: Baskerville - Count Von Count
