window:
  dimensions:
    columns: 263
    lines: 80

font:
  # Normal (roman) font face
  normal:
    # family: Iosevka Extralight
    # family: Fira Code
    # family: Iosevka Nerd Font
    # family: Noto Sans Mono Light
    # family: FuraCode Nerd Font
    # family: FuraCode Nerd Font
    family: FiraCode Nerd Font
    # family: CascadiaCode Nerd Font
    # family: FantasqueSansMono Nerd Font Mono
    # family: VictorMono Nerd Font
    # family: Anonymice Nerd Font
    # family: Iosevka Nerd Font
    # family: SauceCodePro Nerd Font
    # The `style` can be specified to pick a specific face.
    # style: Light
    style: Regular

  size: 16

key_bindings:
  - { key: N, mods: Command, action: CreateNewWindow }

colors:
  name: Garuda (dr460nized)
  author: dr460nf1r3
  primary:
    background: '0x0a1124'
    foreground: '0xeec49a'
  cursor:
    text: '0x0a1124'
    cursor: '0xeec49a'
  normal:
    black: '0x0a1124'
    red: '0x5F4149'
    green: '0xEB3247'
    yellow: '0xBC4349'
    blue: '0xF35645'
    magenta: '0xF6A73B'
    cyan: '0xFAD32F'
    white: '0xeec49a'
  bright:
    black: '0xa6896b'
    red: '0x5F4149'
    green: '0xEB3247'
    yellow: '0xBC4349'
    blue: '0xF35645'
    magenta: '0xF6A73B'
    cyan: '0xFAD32F'
    white: '0xeec49a'
theme: Garuda.dr460nized
